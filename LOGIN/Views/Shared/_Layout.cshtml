@using Microsoft.AspNetCore.Http

@{
    var usuarioId = Context.Session.GetString("UsuarioId");
    var usuarioNombre = Context.Session.GetString("UsuarioNombre");
    var usuarioRol = Context.Session.GetString("UsuarioRol") ?? "";

    bool estaLogueado = !string.IsNullOrEmpty(usuarioId);

    bool esAdmin =
        usuarioRol.Trim().ToLower() == "admin" ||
        usuarioRol.Trim().ToLower() == "administrador";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Mi Inventario</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap"
          rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css"
          rel="stylesheet">

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="manifest" href="/manifest.json">

    <meta name="theme-color" content="#0969DA">

    <link rel="apple-touch-icon"
          href="/icons/icon-192.png">
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark github-navbar sticky-top shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    <i class="bi bi-box-seam me-2 text-info"></i>
                    Another Yet Store
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        @if (estaLogueado && esAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3"
                                   asp-controller="ProductosView"
                                   asp-action="Index">
                                    <i class="bi bi-grid me-1"></i>
                                    Inventario
                                </a>
                            </li>
                        }

                        @if (estaLogueado)
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3"
                                   asp-controller="Tienda"
                                   asp-action="Index">
                                    <i class="bi bi-shop me-1"></i>
                                    Tienda
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link px-3"
                                   asp-controller="Tienda"
                                   asp-action="MisCompras">
                                    <i class="bi bi-bag-check me-1"></i>
                                    Mis Pedidos
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link px-3"
                                   asp-controller="Tienda"
                                   asp-action="AsistenteVoz">

                                    <i class="bi bi-mic-fill me-1"></i>
                                    Voz
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-danger px-3"
                                   asp-controller="Account"
                                   asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-1"></i>
                                    Salir
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link px-3"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>
                                    Iniciar sesión
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link px-3"
                                   asp-controller="Account"
                                   asp-action="Register">
                                    <i class="bi bi-person-plus me-1"></i>
                                    Registrarse
                                </a>
                            </li>
                        }
                    </ul>

                    @if (estaLogueado)
                    {
                        <span class="navbar-text text-white px-3 py-1 rounded-pill border">
                            <i class="bi bi-person-circle me-1"></i>
                            @usuarioNombre

                            @if (esAdmin)
                            {
                                <span class="badge bg-warning text-dark ms-2">
                                    Admin
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark ms-2">
                                    Cliente
                                </span>
                            }
                        </span>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4 pt-3">
        <main role="main">
            @if (TempData["Mensaje"] != null)
            {
                <div class="alert alert-info alert-dismissible fade show" role="alert">
                    @TempData["Mensaje"]
                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="alert"
                            aria-label="Close">
                    </button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="py-3 mt-5">
        <div class="container">
            <small>
                © @DateTime.Now.Year - Todos los derechos reservados
            </small>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
        navigator.serviceWorker
        .register('/service-worker.js')
        .then(reg => {
        console.log('PWA iniciada');
        })
        .catch(err => {
        console.log(err);
        });
        });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>